# ─────────────────────────────────────────────────────────────────────────
# Welfare Management System — Environment Configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────
APP_NAME=Welfare Management System
ENVIRONMENT=development
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────
# SQLite (default, good for local dev):
DATABASE_URL=sqlite:///./welfare.db
# PostgreSQL (recommended for production), example:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/welfare

# ── Security / JWT ───────────────────────────────────────────────────────
# Generate a strong random value, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or "*" to allow all (dev only).
CORS_ORIGINS=*

# ── Default Admin Bootstrap ─────────────────────────────────────────────
# Used only once, to create the admin account if it doesn't already exist.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe@123
ADMIN_FULL_NAME=System Admin

# ── SMTP / Email (Gmail example) ────────────────────────────────────────
# Leave SMTP_SENDER_EMAIL / SMTP_PASSWORD empty to disable outbound email.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SENDER_EMAIL=
# Use a Gmail "App Password" (https://myaccount.google.com/apppasswords), not your normal password.
SMTP_PASSWORD=
